PORT=3000
NODE_ENV=development
DEMO_MODE=true

# Auth — set a strong random token to protect all API endpoints
# Leave blank to disable auth (dev mode only)
API_TOKEN=

# Admin account — seeded on first run
ADMIN_EMAIL=wholefoo@gmail.com
ADMIN_PASSWORD_HASH=$2b$12$...

# CORS — allowed origin for production (e.g., https://yourdomain.com)
CORS_ORIGIN=*

# Stripe — Subscription paywall + White-Label License payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
# Lifetime license ($9,997 one-time) is handled via LICENSE_CONFIG in server.js — no price ID needed

# API Keys — AI Models
ANTHROPIC_API_KEY=your-key-here
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-api-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here
XAI_API_KEY=your-xai-grok-key-here
PERPLEXITY_API_KEY=your-perplexity-key-here

# API Keys — Autonomous Agents
MANUS_API_KEY=your-manus-key-here

# Avatar Voice Pipeline (LiveKit + Deepgram + Cartesia)
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-project.livekit.cloud
DEEPGRAM_API_KEY=your-deepgram-key
CARTESIA_API_KEY=your-cartesia-key

# API Keys — Web Tools
FIRECRAWL_API_KEY=your-firecrawl-key-here
TAVILY_API_KEY=your-tavily-key-here
APIFY_API_TOKEN=your-apify-token-here

# SEO Agency — DataForSEO
DATAFORSEO_LOGIN=your-dataforseo-email
DATAFORSEO_PASSWORD=your-dataforseo-password

# Notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# Hermes Agent — Persistent background worker via MCP
HERMES_MCP_URL=http://127.0.0.1:8420

# Automation
N8N_WEBHOOK_BASE=http://localhost:5678
N8N_API_KEY=your-n8n-api-key-here
TEAM_WEBHOOK_URL=your-team-webhook-url-here
