PORT=3000
NODE_ENV=development
DEMO_MODE=true

# Auth — set a strong random token to protect all API endpoints
# Leave blank to disable auth (dev mode only)
API_TOKEN=

# CORS — allowed origin for production (e.g., https://yourdomain.com)
CORS_ORIGIN=*

# Stripe — Subscription paywall
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# API Keys
ANTHROPIC_API_KEY=your-key-here
FIRECRAWL_API_KEY=your-firecrawl-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here
XAI_API_KEY=your-xai-grok-key-here

# Notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# Automation
N8N_WEBHOOK_BASE=http://localhost:5678
N8N_API_KEY=your-n8n-api-key-here
TEAM_WEBHOOK_URL=your-team-webhook-url-here
